# https://editorconfig.org
# Aligns with GTS/Prettier and project conventions (TypeScript, pnpm)

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{ts,tsx,js,jsx}]
indent_size = 2
quote_type = single

[*.json]
indent_size = 2

# YAML (CI workflows)
[*.{yml,yaml}]
indent_size = 2

# Markdown: allow trailing spaces (used for line breaks in paragraphs)
[*.md]
trim_trailing_whitespace = false

# Shell scripts
[*.sh]
indent_size = 2

# Makefiles require tabs
[Makefile]
indent_style = tab
