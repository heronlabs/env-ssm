# Dependencies (Node)
# https://docs.npmjs.com/cli/v10/configuring-npm/folders#node-modules
node_modules
.pnp
.pnp.js

# Local env files
# https://github.com/github/gitignore/blob/main/Node.gitignore
.env
.env.*

# Testing (Vitest)
coverage
tests/.coverage
*.lcov
.nyc_output

# Integration tests (Playwright)
test-results
playwright-report
.playwright

# Vite (Vitest uses Vite; cache and timestamp files)
# https://vitejs.dev/guide/dep-pre-bundling.html
.vite/
vite.config.*.timestamp-*

# Debug and runtime logs
# https://nodejs.org/api/report.html
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
pids
*.pid
*.seed
*.pid.lock

# Misc (OS, keys, npm pack)
.DS_Store
*.pem
*.tgz

# TypeScript / build info
# https://www.typescriptlang.org/tsconfig#tsbuildinfo
bin/
*.tsconfig.bin.tsbuildinfo
tsconfig.bin.tsbuildinfo
*.tsbuildinfo

# IDE / Editor
# https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
.idea
.eslintcache
.stylelintcache

# Claude Code / internal tooling (never commit to the public repo)
# Exception: supera.json is non-secret shared config that the supera CI
# workflows (audit / pr-watch / start) read from the checkout — deliberately tracked.
.claude/*
!.claude/supera.json

# pnpm
# https://pnpm.io/npmrc#store-dir
.pnpm-store/
.pnpm-debug.log*
.node_history
.node_repl_history
.npm

# Legacy / coverage tooling
lib-cov

# Claude
.superpowers
.worktrees/

# Stryker Mutation
.stryker-tmp
reports
