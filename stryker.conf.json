{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "checkers": [],
  "concurrency": 2,
  "coverageAnalysis": "perTest",
  "dashboard": {
    "project": "@heronlabs/env-ssm"
  },
  "ignorePatterns": ["bin", "node_modules", "reports"],
  "incremental": true,
  "incrementalFile": "reports/mutation/incremental.json",
  "mutate": [
    "src/**/*.ts",
    "!src/main.ts",
    "!src/cli.ts",
    "!src/**/*factory.ts"
  ],
  "mutator": {
    "excludedMutations": ["BlockStatement", "ConditionalExpression"]
  },
  "packageManager": "pnpm",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "reporters": ["clear-text", "progress"],
  "testRunner": "vitest",
  "thresholds": {
    "break": 100,
    "high": 100,
    "low": 100
  },
  "timeoutMS": 15000,
  "vitest": {
    "configFile": "vitest.stryker.config.ts"
  },
  "warnings": {
    "preprocessorErrors": true,
    "slow": true,
    "slowts": true,
    "unknownOptions": false,
    "unserializableOptions": true
  }
}
